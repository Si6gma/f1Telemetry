{
  "name": "@f1t/listener",
  "version": "0.1.0",
  "private": true,
  "description": "UDP listener and packet parser for F1 23 telemetry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@f1t/types": "*",
    "pino": "^8.19.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
