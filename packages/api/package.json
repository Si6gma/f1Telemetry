{
  "name": "@f1t/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify REST API for F1 Telemetry data",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@f1t/types": "*",
    "@fastify/cors": "^9.0.0",
    "fastify": "^4.26.0",
    "pino": "^8.19.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
