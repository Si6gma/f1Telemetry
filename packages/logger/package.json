{
  "name": "@f1t/logger",
  "version": "0.1.0",
  "private": true,
  "description": "SQLite database and telemetry persistence for F1 23",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@f1t/types": "*",
    "@f1t/listener": "*",
    "better-sqlite3": "^9.4.0",
    "drizzle-orm": "^0.29.0",
    "pino": "^8.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
